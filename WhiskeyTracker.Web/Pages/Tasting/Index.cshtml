@page
@model WhiskeyTracker.Web.Pages.Tasting.IndexModel
@{
    ViewData["Title"] = "My Tasting Sessions";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 mb-1">Tasting Sessions</h1>
            <p class="text-muted">High-level record of your past pours.</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#joinSessionModal">
                <i class="bi bi-people me-1"></i> Join Session
            </button>
            <a asp-page="/Tasting/Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Start New Session
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Sessions.Any())
    {
        <div class="alert alert-light border text-center p-5 shadow-sm">
            <h4 class="text-muted mb-3">No sessions found</h4>
            <p class="mb-4 text-muted">You haven't recorded any guided tasting sessions yet.</p>
            <a asp-page="/Tasting/Create" class="btn btn-outline-primary shadow-sm">Create Your First Session</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var session in Model.Sessions)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm hover-shadow transition-all border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0">@(string.IsNullOrEmpty(session.Title) ? "Untitled Session" : session.Title)</h5>
                                <span class="badge bg-white text-dark border shadow-sm">@session.Date.ToShortDateString()</span>
                            </div>
                            
                            <p class="card-text text-muted small">
                                <i class="bi bi-cup-straw me-1"></i> @session.Notes.Count whiskies tasted
                            </p>

                            <div class="d-flex gap-2 mt-4">
                                <a asp-page="./Details" asp-route-id="@session.Id" class="btn btn-sm btn-outline-primary flex-grow-1">
                                    <i class="bi bi-eye me-1"></i> View Details
                                </a>
                                <a asp-page="./Wizard" asp-route-sessionId="@session.Id" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-pencil me-1"></i> Continue / Edit
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    </div>
</div>

<!-- Join Session Modal -->
<div class="modal fade" id="joinSessionModal" tabindex="-1" aria-labelledby="joinSessionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title" id="joinSessionModalLabel">Join Tasting Session</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Join">
                <div class="modal-body p-4">
                    <p class="text-muted mb-4">Enter the 6-character code shared by the session driver to participate in the live tasting.</p>
                    <div class="form-floating mb-3">
                        <input name="joinCode" type="text" class="form-control fw-bold text-center" id="joinCode" placeholder="ABCDEF" required maxlength="10" style="letter-spacing: 0.2rem; font-size: 1.5rem; text-transform: uppercase;">
                        <label for="joinCode">Session Join Code</label>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Join Session</button>
                </div>
            </form>
        </div>
    </div>
</div>

