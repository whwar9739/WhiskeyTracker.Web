@page "{id:int}"
@model WhiskeyTracker.Web.Pages.Tasting.DetailsModel
@{
    ViewData["Title"] = "Session Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
              <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-page="./Index">Tastings</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
              </ol>
            </nav>
            <h1 class="display-6 mb-1">@(string.IsNullOrEmpty(Model.Session.Title) ? "Untitled Session" : Model.Session.Title)</h1>
            <p class="text-muted"><i class="bi bi-calendar3 me-1"></i> @Model.Session.Date.ToLongDateString()</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="./Wizard" asp-route-sessionId="@Model.Session.Id" class="btn btn-outline-success">
                <i class="bi bi-pencil me-1"></i> Edit notes
            </a>
            <a asp-page="./Index" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <h4 class="mb-3 border-bottom pb-2">Full Pours Logged</h4>
            
            @if (!Model.Session.Notes.Any())
            {
                <div class="alert alert-light border p-4 text-center">
                    <p class="mb-0 text-muted">No notes recorded for this session yet.</p>
                </div>
            }
            else
            {
                @foreach (var note in Model.Session.Notes.OrderBy(n => n.OrderIndex))
                {
                    <div class="card mb-3 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h5 class="card-title fw-bold">
                                    <span class="badge bg-secondary rounded-pill me-2">#@note.OrderIndex</span>
                                    @note.Whiskey.Name
                                </h5>
                                <div class="text-warning">
                                    @for (int i = 0; i < note.Rating; i++)
                                    {
                                        <span>★</span>
                                    }
                                </div>
                            </div>
                            
                            <p class="text-muted small mb-2">
                                <strong>Distillery:</strong> @note.Whiskey.Distillery | 
                                <strong>Amount:</strong> @(Math.Round(note.PourAmountMl / 29.5735, 1)) oz
                            </p>

                            @if (!string.IsNullOrEmpty(note.Notes))
                            {
                                <div class="p-3 bg-white rounded border-start border-4 border-primary">
                                    <p class="mb-0 fst-italic">"@note.Notes"</p>
                                </div>
                            }
                            else
                            {
                                <p class="mb-0 text-muted fst-italic">No additional notes provided.</p>
                            }
                        </div>
                    </div>
                }
            }
        </div>
        
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm bg-primary text-white mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Session Stats</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Whiskies Tasted:</span>
                        <span class="fw-bold">@Model.Session.Notes.Count</span>
                    </div>
                    @if (Model.Session.Notes.Any())
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>Average Rating:</span>
                            <span class="fw-bold">@Model.Session.Notes.Average(n => n.Rating).ToString("0.0") ★</span>
                        </div>
                    }
                </div>
            </div>
            
            <div class="alert alert-info shadow-sm" role="alert">
                <i class="bi bi-info-circle-fill me-2"></i>
                You can add more whiskies to this session or edit existing notes using the "Edit notes" button.
            </div>
        </div>
    </div>
</div>
