@page "{sessionId:int}"
@using System.Linq
@using WhiskeyTracker.Web.Data
@model WhiskeyTracker.Web.Pages.Tasting.WizardModel
@{
    ViewData["Title"] = "Tasting Wizard";
}

<style>
    .tag-pill {
        display: inline-flex;
        align-items: center;
        background-color: var(--bs-secondary-bg);
        color: var(--bs-body-color);
        border: 1px solid var(--bs-border-color);
        border-radius: 50px;
        padding: 0.2rem 0.6rem;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }
    .tag-pill:hover {
        background-color: var(--bs-tertiary-bg);
    }
    .tag-pill .btn-close {
        font-size: 0.5rem;
        margin-left: 0.4rem;
        padding: 0.2rem;
    }
    .tag-input:focus {
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.1);
        border-color: #198754;
    }
</style>

<div class="container mt-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h6 class="text-muted text-uppercase mb-1">Current Session</h6>
            <h2 class="mb-0">@Model.Session.Title</h2>
            @if (!string.IsNullOrEmpty(Model.Session.JoinCode))
            {
                <div class="mt-2 text-primary fw-bold" style="letter-spacing: 0.1rem;">
                    <i class="bi bi-people-fill me-1"></i> Join Code: <span class="bg-primary-subtle text-primary-emphasis px-2 py-1 rounded border border-primary-subtle">@Model.Session.JoinCode</span>
                    <small class="text-muted ms-2 fw-normal">(Share this with your friends)</small>
                </div>
            }
        </div>
        <div class="col-md-4 text-end">
            <div id="participants-list" class="d-flex justify-content-end gap-1 mb-2">
                @* Always show owner/driver *@
                <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle shadow-sm" title="Session Owner">
                    <i class="bi bi-person-fill"></i> Driver
                </span>
                @foreach (var p in Model.Session.Participants)
                {
                    <span class="badge rounded-pill bg-body-secondary text-body border shadow-sm" title="Joined at @p.JoinedAt.ToLocalTime().ToShortTimeString()">
                        <i class="bi bi-person-fill text-primary"></i> @(p.User.DisplayName ?? p.User.UserName)
                    </span>
                }
            </div>
            <a asp-page="./Index" class="btn btn-outline-secondary">Finish & Exit</a>
        </div>
    </div>
    <hr />

    <div class="row">
        <div class="col-md-5">
            <div class="card border-primary-subtle shadow-sm">
                <div class="card-header bg-primary-subtle text-primary-emphasis">
                    <h5 class="m-0" id="card-header-title">Pour #@(Model.Session.Notes.Count + 1)</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" id="EditNoteId" name="EditNoteId" value="" />
                        <input type="hidden" asp-for="NoseTags" id="nose-tags-hidden" />
                        <input type="hidden" asp-for="PalateTags" id="palate-tags-hidden" />
                        <input type="hidden" asp-for="FinishTags" id="finish-tags-hidden" />

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success shadow-sm" role="alert">
                                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                            </div>
                        }

                        @if (!ModelState.IsValid)
                        {
                            <div class="alert alert-danger shadow-sm" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Hold on!</strong> Please check
                                the fields below for errors.
                            </div>
                        }

                        <div id="bottle-section" class="mb-3 p-2 bg-body-tertiary border rounded">
                            <label class="form-label fw-bold text-success">Option A: Pour from Inventory</label>
                            <select asp-for="SelectedBottleId" class="form-select bg-body text-body" asp-items="Model.BottleOptions">
                                <option value="">-- Select from Shelf --</option>
                            </select>
                            <span asp-validation-for="SelectedBottleId" class="text-danger"></span>
                            <small class="text-muted">Use this if you are drinking one of your own open bottles.</small>
                        </div>

                        <div id="or-divider" class="text-center mb-3 fw-bold text-muted">- OR -</div>

                        <div id="whiskey-section" class="mb-4 p-2 bg-body-tertiary border rounded">
                            <label class="form-label fw-bold text-primary">Option B: Select Whiskey</label>
                            <select asp-for="SelectedWhiskeyId" class="form-select bg-body text-body" asp-items="Model.WhiskeyOptions">
                                <option value="">-- Select Whiskey --</option>
                            </select>
                            <span asp-validation-for="SelectedWhiskeyId" class="text-danger"></span>
                            <small class="text-muted" id="whiskey-hint">Use this if you are at a bar, friend's house, or the bottle is
                                finished.</small>
                        </div>

                        <hr />

                        <div id="pour-amount-section" class="mb-3">
                            <label asp-for="PourAmountOz" class="form-label">Pour Amount (oz)</label>
                            <input asp-for="PourAmountOz" class="form-control" type="number" step="0.1" placeholder="e.g. 1.5" />
                            <span asp-validation-for="PourAmountOz" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Rating</label>
                            <div class="btn-group w-100" role="group">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <input type="radio" class="btn-check" name="NewNote.Rating" id="rating-@i" value="@i"
                                        autocomplete="off" @(i == 3 ? "checked" : "")>
                                    <label class="btn btn-outline-warning" for="rating-@i">@i ★</label>
                                }
                            </div>
                        </div>

                        <!-- Tagging Section -->
                        <div class="tag-entry-section mb-4">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Nose <small class="text-muted">(Tags)</small></label>
                                <div id="nose-tags-container" class="d-flex flex-wrap gap-1 mb-2"></div>
                                <input type="text" class="form-control form-control-sm tag-input" 
                                       data-field="nose" list="tag-suggestions" placeholder="Add nose tags (e.g. Vanilla, Smoke)..." />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Palate <small class="text-muted">(Tags)</small></label>
                                <div id="palate-tags-container" class="d-flex flex-wrap gap-1 mb-2"></div>
                                <input type="text" class="form-control form-control-sm tag-input" 
                                       data-field="palate" list="tag-suggestions" placeholder="Add palate tags (e.g. Caramel, Spice)..." />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Finish <small class="text-muted">(Tags)</small></label>
                                <div id="finish-tags-container" class="d-flex flex-wrap gap-1 mb-2"></div>
                                <input type="text" class="form-control form-control-sm tag-input" 
                                       data-field="finish" list="tag-suggestions" placeholder="Add finish tags (e.g. Long, Oak)..." />
                            </div>
                        </div>

                        <datalist id="tag-suggestions">
                            @foreach (var tag in Model.AvailableTags)
                            {
                                <option value="@tag.Name" />
                            }
                        </datalist>

                        <div class="mb-3">
                            <label asp-for="NewNote.Notes" class="form-label">Impressions <span class="text-muted">(optional)</span></label>
                            <textarea asp-for="NewNote.Notes" class="form-control" rows="3"
                                placeholder="Nose, Palate, Finish..."></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" id="submit-btn" class="btn btn-primary">Log & Pour Next</button>
                            <button type="button" id="cancel-edit-btn" class="btn btn-outline-secondary d-none" onclick="cancelEdit()">Cancel Edit</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <h4 class="mb-3">Tonight's Lineup</h4>
            @if (Model.Session.Notes.Count == 0)
            {
                <div class="alert alert-secondary border text-center p-4">
                    <p class="mb-0 text-muted">Nothing tasted yet. Pour the first dram!</p>
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var note in Enumerable.Reverse(Model.Session.Notes))
                    {
                        <div class="list-group-item"
                             data-note-id="@note.Id"
                             data-order="@note.OrderIndex"
                             data-rating="@note.Rating"
                             data-notes="@(note.Notes ?? "")"
                             data-whiskey-id="@note.WhiskeyId"
                             data-bottle-id="@(note.BottleId?.ToString() ?? "")"
                             data-pour-ml="@note.PourAmountMl"
                             data-nose-tags="@string.Join(",", note.TastingNoteTags.Where(t => t.Field == TastingField.Nose).Select(t => t.Tag.Name))"
                             data-palate-tags="@string.Join(",", note.TastingNoteTags.Where(t => t.Field == TastingField.Palate).Select(t => t.Tag.Name))"
                             data-finish-tags="@string.Join(",", note.TastingNoteTags.Where(t => t.Field == TastingField.Finish).Select(t => t.Tag.Name))">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <h5 class="mb-1">
                                    <span class="badge bg-secondary rounded-pill me-2">#@note.OrderIndex</span>
                                    @note.Whiskey.Name
                                </h5>
                                <div class="d-flex align-items-center gap-2">
                                    @if (note.PourAmountMl > 0)
                                    {
                                        <small class="text-muted">@(Math.Round(note.PourAmountMl / 29.5735, 1)) oz</small>
                                    }
                                    <small class="text-warning opacity-75">
                                        @for (int k = 0; k < note.Rating; k++)
                                        {
                                            <span>★</span>
                                        }
                                    </small>
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            onclick="startEdit(this)">Edit</button>
                                </div>
                            </div>
                            @if (note.TastingNoteTags.Any())
                            {
                                <div class="mt-2">
                                    @foreach(var group in note.TastingNoteTags.GroupBy(tg => tg.Field))
                                    {
                                        <div class="mb-1">
                                            <small class="text-muted fw-bold me-1">@group.Key:</small>
                                            @foreach(var tg in group)
                                            {
                                                <span class="badge rounded-pill bg-body-secondary text-body border me-1">@tg.Tag.Name</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            <p class="mb-1 mt-2 text-muted" style="font-style: italic;">@note.Notes</p>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            var $alerts = $('.alert');
            if ($alerts.length) {
                setTimeout(function () { $alerts.fadeOut('slow'); }, 4000);
            }
        });
    </script>

    <script>
        // Ensure only one of the two selects can be chosen
        $(document).ready(function () {
            $('#SelectedBottleId').change(function () {
                if ($(this).val()) $('#SelectedWhiskeyId').val('');
            });
            $('#SelectedWhiskeyId').change(function () {
                if ($(this).val()) $('#SelectedBottleId').val('');
            });
        });
    </script>

    <script>
        var originalPourNumber = '@(Model.Session.Notes.Count + 1)';
        var tagState = {
            nose: [],
            palate: [],
            finish: []
        };

        $(document).ready(function () {
            // Initialize tag inputs
            $('.tag-input').on('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ',') {
                    e.preventDefault();
                    var val = $(this).val().trim().replace(/,/g, '');
                    if (val) {
                        addTag($(this).data('field'), val);
                        $(this).val('');
                    }
                }
            });

            // Handle selection from datalist
            $('.tag-input').on('input', function() {
                var val = $(this).val();
                var field = $(this).data('field');
                var options = $('#tag-suggestions option');
                for (var i = 0; i < options.length; i++) {
                    if (options[i].value === val) {
                        addTag(field, val);
                        $(this).val('');
                        break;
                    }
                }
            });
        });

        function addTag(field, name) {
            name = name.toLowerCase();
            if (!tagState[field].includes(name)) {
                tagState[field].push(name);
                renderTags(field);
                updateHiddenFields();
            }
        }

        function removeTag(field, name) {
            tagState[field] = tagState[field].filter(t => t !== name);
            renderTags(field);
            updateHiddenFields();
        }

        function renderTags(field) {
            var container = $('#' + field + '-tags-container');
            container.empty();
            tagState[field].forEach(tag => {
                var pill = $('<div class="tag-pill shadow-sm"></div>').text(tag);
                var close = $('<button type="button" class="btn-close" aria-label="Remove"></button>');
                close.click(() => removeTag(field, tag));
                pill.append(close);
                container.append(pill);
            });
        }

        function updateHiddenFields() {
            $('#nose-tags-hidden').val(tagState.nose.join(','));
            $('#palate-tags-hidden').val(tagState.palate.join(','));
            $('#finish-tags-hidden').val(tagState.finish.join(','));
        }

        function startEdit(btn) {
            var item = $(btn).closest('.list-group-item');
            var noteId    = item.data('note-id');
            var order     = item.data('order');
            var rating    = item.data('rating');
            var notes     = item.data('notes');
            var whiskeyId = item.data('whiskey-id');
            var bottleId  = item.data('bottle-id');
            var pourMl    = item.data('pour-ml');
            
            var noseTags   = item.data('nose-tags');
            var palateTags = item.data('palate-tags');
            var finishTags = item.data('finish-tags');

            // Set hidden edit field
            $('#EditNoteId').val(noteId);

            // Pre-populate tags
            tagState.nose = noseTags ? String(noseTags).split(',').filter(t => t) : [];
            tagState.palate = palateTags ? String(palateTags).split(',').filter(t => t) : [];
            tagState.finish = finishTags ? String(finishTags).split(',').filter(t => t) : [];
            
            renderTags('nose');
            renderTags('palate');
            renderTags('finish');
            updateHiddenFields();

            // Pre-populate the right selector based on how the note was originally logged
            if (bottleId) {
                $('#SelectedBottleId').val(String(bottleId));
                $('#SelectedWhiskeyId').val('');
            } else {
                $('#SelectedWhiskeyId').val(String(whiskeyId));
                $('#SelectedBottleId').val('');
            }

            // Pre-populate pour amount (convert ml back to oz, rounded to 1 decimal)
            $('#PourAmountOz').val(pourMl > 0 ? Math.round((pourMl / 29.5735) * 10) / 10 : '');

            // Set rating and notes
            $('input[name="NewNote.Rating"][value="' + rating + '"]').prop('checked', true);
            $('#NewNote_Notes').val(notes);

            // Update UI
            $('#card-header-title').text('Editing Pour #' + order);
            $('#submit-btn').text('Save Changes').removeClass('btn-primary').addClass('btn-success');
            $('#cancel-edit-btn').removeClass('d-none');

            // Scroll to form
            $('html, body').animate({ scrollTop: $('.card').offset().top - 20 }, 300);
        }

        function cancelEdit() {
            $('#EditNoteId').val('');
            $('#SelectedBottleId').val('');
            $('#SelectedWhiskeyId').val('');
            $('#PourAmountOz').val('');
            $('input[name="NewNote.Rating"][value="3"]').prop('checked', true);
            $('#NewNote_Notes').val('');
            
            tagState.nose = [];
            tagState.palate = [];
            tagState.finish = [];
            renderTags('nose');
            renderTags('palate');
            renderTags('finish');
            updateHiddenFields();

            $('#card-header-title').text('Pour #' + originalPourNumber);
            $('#submit-btn').text('Log & Pour Next').removeClass('btn-success').addClass('btn-primary');
            $('#cancel-edit-btn').addClass('d-none');
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const sessionId = "@Model.Session.Id";
        const currentUserId = "@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)";
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/tastingHub")
            .withAutomaticReconnect()
            .build();

        function showToast(title, message, icon, color, showButton = false) {
            const toastId = 'toast-' + Date.now();
            const toastHtml = `
                <div id="${toastId}" class="toast show align-items-center text-white bg-${color} border-0 mb-2 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi ${icon} me-2"></i><strong>${title}</strong>: ${message}
                            ${showButton ? `<button type="button" class="btn btn-sm btn-light ms-2 px-3 py-0" onclick="location.reload()">Refresh Lineup</button>` : ''}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>`;
            
            if (!$('#toast-container').length) {
                $('body').append('<div id="toast-container" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060"></div>');
            }
            $('#toast-container').append(toastHtml);
            
            // Auto-remove after 8 seconds
            setTimeout(() => {
                const $t = $(`#${toastId}`);
                if ($t.length) {
                    $t.fadeOut('slow', function() { $(this).remove(); });
                }
            }, 8000);
        }

        connection.on("WhiskeyAdded", function (whiskeyName, userName) {
            showToast('New Whiskey', `${userName} added <strong>${whiskeyName}</strong> to the lineup!`, 'bi-plus-circle-fill', 'success', true);
        });

        connection.on("NoteUpdated", function (userName) {
            showToast('Note Updated', `${userName} updated their tasting note.`, 'bi-pencil-square', 'info', true);
        });

        connection.on("ParticipantJoined", function (userName) {
            // Update the UI list immediately
            if ($('#participants-list').length) {
                const badge = $('<span class="badge rounded-pill bg-info text-body border shadow-sm ms-1 animated pulse"><i class="bi bi-person-plus-fill"></i> ' + userName + '</span>');
                $('#participants-list').append(badge);
            }
            showToast('Participant Joined', `${userName} joined the session!`, 'bi-person-plus-fill', 'primary');
        });

        connection.start().then(function () {
            console.log("SignalR Connected");
            connection.invoke("JoinSession", sessionId);
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}
