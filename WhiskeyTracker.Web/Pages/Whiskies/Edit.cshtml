@page "{id:int}"
@model WhiskeyTracker.Web.Pages.Whiskies.EditModel
@{
    ViewData["Title"] = "Edit Whiskey";
}

<h1>Edit Whiskey</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <input type="hidden" asp-for="Whiskey.Id" />

            <input type="hidden" asp-for="Whiskey.ImageFileName" />

            <div class="mb-3 text-center">
                @if (!string.IsNullOrEmpty(Model.Whiskey.ImageFileName))
                {
                    <p>Current Image:</p>
                    <img src="~/images/@Model.Whiskey.ImageFileName" style="max-height: 200px;" class="img-thumbnail" />
                }
            </div>

            <input type="hidden" asp-for="GooglePhotoUrl" id="GooglePhotoUrl" />
            <input type="hidden" asp-for="GooglePhotoToken" id="GooglePhotoToken" />
            <div class="form-group mb-3">
                <label class="form-label">Change Image</label>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="requestGooglePhotosAccess()">
                        <i class="bi bi-google"></i> Browse Google Photos
                    </button>
                    <span class="text-muted small">or upload from device:</span>
                </div>
                <input type="file" asp-for="ImageUpload" class="form-control" accept="image/*" id="ImageUpload" onchange="clearGooglePhoto()" />
                <div id="googlePhotoPreviewContainer" class="mt-2 d-none">
                    <p class="mb-1 small text-success"><i class="bi bi-check-circle-fill me-1"></i> Google Photo Selected:</p>
                    <div class="position-relative d-inline-block">
                        <img id="googlePhotoPreview" src="" style="max-height: 150px;" class="img-thumbnail shadow-sm" />
                        <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1" onclick="clearGooglePhoto()" aria-label="Remove"><i class="bi bi-x"></i></button>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Whiskey.Brand" class="form-label"></label>
                <input asp-for="Whiskey.Brand" class="form-control" />
                <span asp-validation-for="Whiskey.Brand" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Whiskey.Distillery" class="form-label"></label>
                <input asp-for="Whiskey.Distillery" class="form-control" />
                <span asp-validation-for="Whiskey.Distillery" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Whiskey.Name" class="form-label"></label>
                <input asp-for="Whiskey.Name" class="form-control" />
                <span asp-validation-for="Whiskey.Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Whiskey.Region" class="form-label"></label>
                <input asp-for="Whiskey.Region" class="form-control" />
                <span asp-validation-for="Whiskey.Region" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Whiskey.Type" class="form-label"></label>
                <input asp-for="Whiskey.Type" class="form-control" placeholder="e.g. Single Malt" />
                <span asp-validation-for="Whiskey.Type" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Whiskey.Age" class="form-label"></label>
                    <input asp-for="Whiskey.Age" class="form-control" placeholder="e.g. 12" />
                    <span asp-validation-for="Whiskey.Age" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Whiskey.ABV" class="form-label"></label>
                    <input asp-for="Whiskey.ABV" class="form-control" placeholder="e.g. 43.5" />
                    <span asp-validation-for="Whiskey.ABV" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Whiskey.CaskType" class="form-label"></label>
                <input asp-for="Whiskey.CaskType" class="form-control" placeholder="e.g. Sherry Oak" />
                <span asp-validation-for="Whiskey.CaskType" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Whiskey.GeneralNotes" class="form-label">General Notes</label>
                <textarea asp-for="Whiskey.GeneralNotes" class="form-control" rows="5" placeholder="Your overall thoughts, flavor profile summary, etc."></textarea>
                <span asp-validation-for="Whiskey.GeneralNotes" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
                <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <partial name="_GooglePhotosPicker" />
    <script>
        function selectGooglePhoto(fullUrl, previewUrl, token) {
            document.getElementById('GooglePhotoUrl').value = fullUrl;
            document.getElementById('GooglePhotoToken').value = token;
            document.getElementById('googlePhotoPreview').src = previewUrl;
            document.getElementById('googlePhotoPreviewContainer').classList.remove('d-none');
            document.getElementById('ImageUpload').value = '';
        }

        function clearGooglePhoto() {
            document.getElementById('GooglePhotoUrl').value = '';
            document.getElementById('GooglePhotoToken').value = '';
            document.getElementById('googlePhotoPreview').src = '';
            document.getElementById('googlePhotoPreviewContainer').classList.add('d-none');
        }
    </script>
}