@page
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model WhiskeyTracker.Web.Pages.Whiskies.IndexModel
@{
    ViewData["Title"] = "My Whiskey Library";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>My Whiskey Library</h1>
    <a asp-page="./Create" class="btn btn-primary">
        + Log New Whiskey
    </a>
</div>

<form class="row g-3 mb-4 p-3 bg-body-tertiary rounded shadow-sm" method="get">
    <div class="col-md-4">
        <label class="form-label fw-bold small text-muted">Search</label>
        <input type="text" asp-for="SearchString" class="form-control bg-body text-body" placeholder="Distiller or Name..." />
    </div>
    <div class="col-md-3">
        <label class="form-label fw-bold small text-muted">Region</label>
        <select asp-for="WhiskeyRegion" asp-items="Model.Regions" class="form-select bg-body text-body">
            <option value="">All Regions</option>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label fw-bold small text-muted">Bottle Status</label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<WhiskeyTracker.Web.Data.BottleStatus>()" class="form-select bg-body text-body">
            <option value="">Any Status</option>
        </select>
    </div>
    <div class="col-md-4 d-flex align-items-center">
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" type="checkbox" asp-for="ShowOnlyMyCollection" id="showOnlyMyCollection">
            <label class="form-check-label fw-bold small text-muted" for="showOnlyMyCollection">
                Show My Collection Only
            </label>
        </div>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-secondary w-100">Filter</button>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <a asp-page="./Index" class="btn btn-outline-secondary w-100">Reset</a>
    </div>
</form>
@if (Model.Whiskies.Count == 0)
{
    <div class="alert alert-info">
        @if (!string.IsNullOrEmpty(Model.SearchString) || !string.IsNullOrEmpty(Model.WhiskeyRegion))
        {
            <span>No whiskies match your search. <a asp-page="./Index">Clear filters</a> to see your library.</span>
        }
        else
        {
            <span>You haven't logged any whiskies yet. Click the button above to add your first bottle!</span>
        }
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th>Distillery</th>
                <th>Name / Expression</th>
                <th>Region</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Whiskies)
            {
                <tr style="cursor: pointer;" onclick="if(!event.target.closest('a, button, img')) { window.location.href='@Url.Page("./Details", new { id = item.Id })'; }">
                    <td style="width: 100px;">
                        @if (!string.IsNullOrEmpty(item.ImageFileName))
                        {
                            <img src="~/images/@item.ImageFileName" alt="Bottle of @item.Name" class="img-thumbnail"
                                style="max-height: 80px; cursor: pointer;" 
                                data-bs-toggle="modal" data-bs-target="#imageModal" data-image-src="/images/@item.ImageFileName" />
                        }
                        else
                        {
                            <span class="text-muted small">No Image</span>
                        }
                    </td>
                    <td class="fw-bold">@item.Distillery</td>
                    <td>@item.Name</td>
                    <td>@item.Region</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-page="./AddBottle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">+ Bottle</a>
                        <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Image Preview Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pt-0">
                <img id="previewImage" src="" alt="Whiskey Preview" class="img-fluid rounded shadow-sm" style="max-height: 80vh;" />
            </div>
        </div>
    </div>
</div>

@if (TempData["PromptAddBottle"] != null)
{
    var newWhiskeyId = TempData["NewWhiskeyId"];
    <!-- Add Bottle Prompt Modal -->
    <div class="modal fade" id="addBottlePromptModal" tabindex="-1" aria-labelledby="addBottlePromptModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success-subtle text-success-emphasis border-bottom border-success-subtle">
                    <h5 class="modal-title" id="addBottlePromptModalLabel"><i class="bi bi-check-circle me-2"></i>Whiskey Created!</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body fs-5 text-center py-4">
                    You've successfully added this whiskey to the library. <br/><br/>
                    Would you like to add a bottle of it to your collection now?
                </div>
                <div class="modal-footer justify-content-center border-0 pb-4">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Later</button>
                    <a href="@Url.Page("./AddBottle", new { id = newWhiskeyId })" class="btn btn-primary px-4">Yes, Add Bottle</a>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var imageModal = document.getElementById('imageModal');
            imageModal.addEventListener('show.bs.modal', function (event) {
                // Button that triggered the modal (in this case, the image itself)
                var button = event.relatedTarget;
                // Extract info from data-image-src attributes
                var imageUrl = button.getAttribute('data-image-src');
                var altText = button.getAttribute('alt');
                
                // Update the modal's content.
                var modalImg = imageModal.querySelector('#previewImage');
                modalImg.src = imageUrl;
                modalImg.alt = altText;
            });

            @if (TempData["PromptAddBottle"] != null)
            {
                <text>
                var addBottleModal = new bootstrap.Modal(document.getElementById('addBottlePromptModal'));
                addBottleModal.show();
                </text>
            }
        });
    </script>
}