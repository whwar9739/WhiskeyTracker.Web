@page
@model WhiskeyTracker.Web.Pages.Whiskies.CreateModel
@{
    ViewData["Title"] = "Log a New Whiskey";
}

<div class="container mt-4">
    <h1>Log a New Whiskey</h1>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-group mb-3">
                    <label asp-for="NewWhiskey.Distillery" class="form-label">Distillery</label>
                    <input asp-for="NewWhiskey.Distillery" class="form-control" placeholder="e.g. Macallan" />
                    <span asp-validation-for="NewWhiskey.Distillery" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="NewWhiskey.Name" class="form-label">Name / Expression</label>
                    <input asp-for="NewWhiskey.Name" class="form-control" placeholder="e.g. 12 Year Sherry Oak" />
                    <span asp-validation-for="NewWhiskey.Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="NewWhiskey.Brand" class="form-label">Brand</label>
                    <input asp-for="NewWhiskey.Brand" class="form-control" placeholder="e.g. Macallan" />
                    <span asp-validation-for="NewWhiskey.Brand" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="NewWhiskey.Region" class="form-label">Region</label>
                    <input asp-for="NewWhiskey.Region" class="form-control" placeholder="e.g. Speyside" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="NewWhiskey.Type" class="form-label">Type</label>
                    <input asp-for="NewWhiskey.Type" class="form-control" placeholder="e.g. Single Malt" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NewWhiskey.Age" class="form-label"></label>
                        <input asp-for="NewWhiskey.Age" class="form-control" placeholder="e.g. 12" />
                        <span asp-validation-for="NewWhiskey.Age" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="NewWhiskey.ABV" class="form-label"></label>
                        <input asp-for="NewWhiskey.ABV" class="form-control" placeholder="e.g. 43.5" />
                        <span asp-validation-for="NewWhiskey.ABV" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="NewWhiskey.CaskType" class="form-label"></label>
                    <input asp-for="NewWhiskey.CaskType" class="form-control" placeholder="e.g. Sherry Oak" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="NewWhiskey.GeneralNotes" class="form-label">General Notes</label>
                    <textarea asp-for="NewWhiskey.GeneralNotes" class="form-control" rows="5" placeholder="Your overall thoughts, flavor profile summary, etc."></textarea>
                    <span asp-validation-for="NewWhiskey.GeneralNotes" class="text-danger"></span>
                </div>

                <input type="hidden" asp-for="GooglePhotoUrl" id="GooglePhotoUrl" />
                <input type="hidden" asp-for="GooglePhotoToken" id="GooglePhotoToken" />
                <div class="form-group mb-3">
                    <label class="form-label">Bottle Image</label>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="requestGooglePhotosAccess()">
                            <i class="bi bi-google"></i> Browse Google Photos
                        </button>
                        <span class="text-muted small">or upload from device:</span>
                    </div>
                    <input type="file" asp-for="ImageUpload" class="form-control" accept="image/*" id="ImageUpload" onchange="clearGooglePhoto()" />
                    <div id="googlePhotoPreviewContainer" class="mt-2 d-none">
                        <p class="mb-1 small text-success"><i class="bi bi-check-circle-fill me-1"></i> Google Photo Selected:</p>
                        <div class="position-relative d-inline-block">
                            <img id="googlePhotoPreview" src="" style="max-height: 150px;" class="img-thumbnail shadow-sm" />
                            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1" onclick="clearGooglePhoto()" aria-label="Remove"><i class="bi bi-x"></i></button>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <input type="submit" value="Log Whiskey" class="btn btn-primary" />
                    <a asp-page="/Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <partial name="_GooglePhotosPicker" />
    <script>
        function selectGooglePhoto(fullUrl, previewUrl, token) {
            document.getElementById('GooglePhotoUrl').value = fullUrl;
            document.getElementById('GooglePhotoToken').value = token;
            document.getElementById('googlePhotoPreview').src = previewUrl;
            document.getElementById('googlePhotoPreviewContainer').classList.remove('d-none');
            document.getElementById('ImageUpload').value = '';
        }

        function clearGooglePhoto() {
            document.getElementById('GooglePhotoUrl').value = '';
            document.getElementById('GooglePhotoToken').value = '';
            document.getElementById('googlePhotoPreview').src = '';
            document.getElementById('googlePhotoPreviewContainer').classList.add('d-none');
            // Re-enable validation for file if needed or just let it be
        }
    </script>
}