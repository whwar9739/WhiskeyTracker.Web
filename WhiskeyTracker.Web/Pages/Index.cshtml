@page
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model IndexModel
@{
    ViewData["Title"] = User.Identity?.IsAuthenticated == true ? "Dashboard" : "Welcome";
}

@if (User.Identity?.IsAuthenticated != true)
{
    <div class="text-center py-5">
        <img src="~/images/logo-light.png" alt="Evolving Pour" height="120" class="logo-light mb-4" />
        <img src="~/images/logo-dark.png" alt="Evolving Pour" height="120" class="logo-dark mb-4" />
        <h1 class="display-4 fw-bold">Evolving Pour</h1>
        <p class="lead text-muted mb-4">Your personal whiskey inventory and tasting journal.</p>
        <p class="text-muted mb-5 mx-auto" style="max-width: 540px;">
            Track your collection, log tasting notes, run guided sessions with friends,
            and build a record of every dram you've explored.
        </p>
        <a asp-page="/Account/Login" asp-area="Identity" class="btn btn-primary btn-lg px-5">Sign In to Get Started</a>
        <div class="mt-5 row justify-content-center g-4 text-start" style="max-width: 720px; margin: auto;">
            <div class="col-md-4">
                <div class="p-4 border rounded bg-body-tertiary h-100">
                    <h5 class="fw-bold">Bottle Inventory</h5>
                    <p class="text-muted small mb-0">Track every bottle — full, opened, or finished — with purchase details and images.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border rounded bg-body-tertiary h-100">
                    <h5 class="fw-bold">Tasting Sessions</h5>
                    <p class="text-muted small mb-0">Run guided tasting sessions solo or with a group and capture notes in real time.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border rounded bg-body-tertiary h-100">
                    <h5 class="fw-bold">Shared Collections</h5>
                    <p class="text-muted small mb-0">Invite friends to join your collection and explore whiskies together.</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Whiskey Tracker</h1>
    <p class="lead text-muted">Catalog your collection. Journal your tastings.</p>
</div>

<div class="row mb-5 align-items-center">
    <div class="col-md-6">
        <h1 class="display-5 fw-bold">Welcome Back!</h1>
        <p class="text-muted">Here is what's happening in your cellar.</p>
    </div>
    <div class="col-md-6">
        <div class="row g-2 text-center">
            <div class="col-4">
                <a asp-page="/Whiskies/Index" asp-route-ShowOnlyMyCollection="true" class="text-decoration-none">
                    <div class="p-3 border bg-body-tertiary rounded shadow-sm hover-shadow transition-all">
                        <h2 class="fw-bold text-primary mb-0">@Model.TotalWhiskies</h2>
                        <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Expressions</small>
                    </div>
                </a>
            </div>
            <div class="col-4">
                <a href="/Whiskies?ShowOnlyMyCollection=true&Statuses=Opened&Statuses=Full" class="text-decoration-none">
                    <div class="p-3 border bg-body-tertiary rounded shadow-sm hover-shadow transition-all">
                        <h2 class="fw-bold text-success mb-0">@Model.OpenBottles</h2>
                        <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Available Bottles</small>
                    </div>
                </a>
            </div>
            <div class="col-4">
                <a asp-page="/Tasting/Index" class="text-decoration-none">
                    <div class="p-3 border bg-body-tertiary rounded shadow-sm hover-shadow transition-all">
                        <h2 class="fw-bold text-warning mb-0">@Model.TotalSessions</h2>
                        <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Sessions</small>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow border-primary-subtle transition-all">
            <div class="card-body text-center p-5 d-flex flex-column">
                <h2 class="card-title text-primary mb-3">🥃 Tasting Session</h2>
                <p class="card-text mb-4">
                    Pouring a dram? Start a guided session to record your notes and ratings in real-time.
                </p> 
                <div class="d-grid gap-2 mt-auto">
                    <a asp-page="/Tasting/Create" class="btn btn-primary btn-lg">Start New Session</a>
                    <button type="button" class="btn btn-outline-primary btn-lg" data-bs-toggle="modal" data-bs-target="#joinSessionModal">Join a Session</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow border-secondary transition-all">
            <div class="card-body text-center p-5 d-flex flex-column">
                <h2 class="card-title text-secondary mb-3">➕ Log New</h2>
                <p class="card-text mb-4">
                    Picked up something new? Add it to your database.
                </p>
                <div class="d-grid mt-auto">
                    <a asp-page="/Whiskies/Create" class="btn btn-success btn-lg">Add Bottle</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow border-secondary transition-all">
            <div class="card-body text-center p-5 d-flex flex-column">
                <h2 class="card-title text-secondary mb-3">📚 My Whiskies</h2>
                <p class="card-text mb-4">
                    Add new purchases, update inventory status, or browse your existing collection.
                </p>
                <div class="d-grid mt-auto">
                    <a asp-page="/Whiskies/Index" class="btn btn-outline-secondary btn-lg">View Collection</a>
                </div>
            </div>
        </div>
    </div>
</div>

<h4 class="mb-3 border-bottom pb-2">Recent Sips</h4>
@if (Model.RecentNotes.Count == 0)
{
    <p class="text-muted fst-italic">No tastings recorded yet. Start your first session above!</p>
}
else
{
    <div class="list-group">
        @foreach (var note in Model.RecentNotes)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0 fw-bold">@note.Whiskey.Name</h6>
                    @if (note.TastingNoteTags.Any())
                    {
                        <div class="mt-1">
                            @foreach(var tg in note.TastingNoteTags.Take(3))
                            {
                                <span class="badge rounded-pill bg-body-secondary text-body border me-1" style="font-size: 0.7rem;">@tg.Tag.Name</span>
                            }
                        </div>
                    }
                    <small class="text-muted d-block mt-1">@note.Notes</small>
                </div>
                <div class="text-end">
                    <span class="text-warning">
                        @for (int i = 0; i < note.Rating; i++)
                        {
                            <span>★</span>
                        }
                    </span>
                </div>
            </div>
        }
    </div>
}

<!-- Join Session Modal -->
<div class="modal fade" id="joinSessionModal" tabindex="-1" aria-labelledby="joinSessionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary-subtle text-primary-emphasis border-bottom border-primary-subtle">
                <h5 class="modal-title" id="joinSessionModalLabel">Join Tasting Session</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page="/Tasting/Index" asp-page-handler="Join">
                <div class="modal-body p-4">
                    <p class="text-muted mb-4">Enter the 6-character code shared by the session driver to participate in the live tasting.</p>
                    <div class="form-floating mb-3">
                        <input name="joinCode" type="text" class="form-control fw-bold text-center" id="joinCode" placeholder="ABCDEF" required maxlength="10" style="letter-spacing: 0.2rem; font-size: 1.5rem; text-transform: uppercase;">
                        <label for="joinCode">Session Join Code</label>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Join Session</button>
                </div>
            </form>
        </div>
    </div>
</div>
} @* end else (authenticated) *@