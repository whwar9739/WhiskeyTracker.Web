@page
@model WhiskeyTracker.Web.Pages.Admin.TagsModel
@{
    ViewData["Title"] = "Manage Tags";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Tag Management</h2>
        <a asp-page="./Index" class="btn btn-outline-secondary btn-sm">Back to Admin</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Pending Review (@Model.PendingTags.Count)</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.PendingTags.Any())
                    {
                        <div class="p-3 text-center text-muted">No pending tags. Good job!</div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tag Name</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tag in Model.PendingTags)
                                {
                                    <tr>
                                        <td class="align-middle">
                                            <span class="fw-bold">@tag.Name</span>
                                        </td>
                                        <td class="text-end">
                                            <form method="post" asp-page-handler="Approve" asp-route-id="@tag.Id" class="d-inline">
                                                <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                            </form>
                                            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#mergeModal" 
                                                    onclick="prepareMerge(@tag.Id, '@tag.Name')">Merge</button>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@tag.Id" class="d-inline" 
                                                  onsubmit="return confirm('Are you sure you want to delete this tag?')">
                                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Approved Tags (@Model.ApprovedTags.Count)</h5>
                </div>
                <div class="card-body p-0" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0">
                        <tbody>
                            @foreach (var tag in Model.ApprovedTags)
                            {
                                <tr>
                                    <td class="ps-3 align-middle">@tag.Name</td>
                                    <td class="text-end pe-3">
                                        <button type="button" class="btn btn-link btn-sm text-primary p-0 me-2" 
                                                data-bs-toggle="modal" data-bs-target="#mergeModal" 
                                                onclick="prepareMerge(@tag.Id, '@tag.Name')">Merge</button>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@tag.Id" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this tag? All associations will be removed.')">
                                            <button type="submit" class="btn btn-link btn-sm text-danger p-0">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Merge Modal -->
<div class="modal fade" id="mergeModal" tabindex="-1" aria-labelledby="mergeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Merge">
                <div class="modal-header">
                    <h5 class="modal-title" id="mergeModalLabel">Merge Tag</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>You are merging the tag <strong id="sourceTagName"></strong> into another tag.</p>
                    <p class="text-muted small">This will update all tasting notes using the old tag to use the new one instead.</p>
                    
                    <input type="hidden" name="sourceId" id="sourceTagId" />
                    
                    <div class="mb-3">
                        <label class="form-label">Target Tag</label>
                        <select name="targetId" class="form-select" required>
                            <option value="">-- Select Target --</option>
                            @foreach (var tag in Model.ApprovedTags)
                            {
                                <option value="@tag.Id">@tag.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-toggle="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Execute Merge</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function prepareMerge(id, name) {
            document.getElementById('sourceTagId').value = id;
            document.getElementById('sourceTagName').innerText = name;
        }
    </script>
}
